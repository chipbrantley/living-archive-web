---
import '../../styles/global.css';
import UserMenu from '../../components/UserMenu.astro';
import { fetchPhotographerBySlug, fetchImagesByIds } from '../../lib/airtable';
import type { AirtablePhotographer, AirtableImage } from '../../lib/airtable';
import { watermarkLine, photographerConfigBySlug } from '../../lib/photographers';
import { repositoryBySlug } from '../../lib/repositories';

const { slug } = Astro.params;

// Collection-level reproductions facts (which estate grants permission, which
// archive holds the negatives, its call number and finding aid). A collection
// maps 1:1 to a photographer, so this is where that guidance belongs; the
// repository page carries only the shared institutional half.
const config = photographerConfigBySlug(slug ?? '');
const collection = config?.collection ?? null;
const holdingRepository = collection ? repositoryBySlug(collection.repositorySlug) : null;

let photographer: AirtablePhotographer | null = null;
let images: AirtableImage[] = [];
let error: string | null = null;

try {
  photographer = await fetchPhotographerBySlug(slug ?? '');
  if (photographer && photographer.imageIds.length > 0) {
    images = (await fetchImagesByIds(photographer.imageIds)).filter((i) => i.imageFile);
  }
} catch (e) {
  error = e instanceof Error ? e.message : 'Unknown error.';
}

const pageTitle = photographer
  ? `${photographer.name} — Living Archive`
  : 'Photographer not found — Living Archive';
const metaLine = photographer
  ? [photographer.activeDates, photographer.rightsHolder].filter(Boolean).join(' · ')
  : '';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href="/">
          <span class="brand-title">Living Archive</span>
        </a>
        <UserMenu />
      </div>
    </header>

    <nav class="breadcrumb">
      <a href="/">Browse</a>
      <span class="sep">›</span>
      <span>{photographer ? photographer.name : 'Photographer'}</span>
    </nav>

    <div class="page">
      {error && (
        <div class="card">
          <div class="error-card">
            <strong>Something went wrong.</strong>
            <pre>{error}</pre>
          </div>
        </div>
      )}

      {!error && !photographer && (
        <div class="card">
          <h1 class="title">Photographer not found</h1>
          <p>
            We don't have a photographer by that name yet.
            <a href="/">Back to browse</a>
          </p>
        </div>
      )}

      {photographer && (
        <>
          <section class="intro photographer-intro">
            {photographer.portraitUrl && (
              <img class="photographer-portrait" src={photographer.portraitUrl} alt={`Portrait of ${photographer.name}`} loading="lazy" />
            )}
            <div class="photographer-intro-body">
              <h1 class="intro-title">{photographer.name}</h1>
              {metaLine && <div class="place-line">{metaLine}</div>}
              {photographer.bio && photographer.bio.split(/\n+/).filter(Boolean).map((para) => (
                <p class="intro-text">{para}</p>
              ))}
            </div>
          </section>

          {(collection || config?.rightsHolder) && (
            <section class="intro repository-intro" id="reproductions">
              <div class="repository-request">
                <h2 class="repository-request-title">Collection &amp; reproductions</h2>

                {collection ? (
                  <p class="intro-text">
                    {photographer.name}'s negatives, contact sheets, and high-resolution scans are
                    held in the {collection.name}
                    {collection.number ? ` (${collection.number})` : ''}
                    {holdingRepository ? ' at ' : ''}
                    {holdingRepository && (
                      <a href={`/repository/${holdingRepository.slug}`}>{holdingRepository.name}</a>
                    )}.
                    {config?.rightsHolder && (
                      <> Permission to reproduce is granted by {config.rightsHolder}, while the
                      high-resolution file is supplied by the repository — a request generally needs
                      to reach both.</>
                    )}
                  </p>
                ) : (
                  <p class="intro-text">
                    Permission to reproduce {photographer.name}'s work is granted by {config!.rightsHolder}.
                  </p>
                )}

                {collection?.citation && (
                  <div class="citation-block">
                    <div class="citation-label">Credit line for publication</div>
                    <p class="citation-text">{collection.citation}</p>
                  </div>
                )}

                {collection?.links && collection.links.length > 0 && (
                  <ul class="repository-links">
                    {collection.links.map((link) => (
                      <li>
                        <a href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </section>
          )}

          {images.length === 0 && (
            <div class="card" style="margin-top:24px">
              <p>No photographs by {photographer.name} are on the site yet.</p>
            </div>
          )}

          {images.length > 0 && (
            <section class="section">
              <div class="browse-header">
                <h2 class="browse-title">Photographs by {photographer.name}</h2>
                <span class="browse-count">{images.length} {images.length === 1 ? 'image' : 'images'}</span>
              </div>
              <div class="grid">
                {images.map((img) => (
                  <a class="tile" href={`/image/${img.imageNumber}`}>
                    <div class="tile-image-wrap">
                      <img src={img.imageFile!.displayUrl} alt={img.caption ?? `Image ${img.imageNumber}`} loading="lazy" />
                      <span class="image-watermark image-watermark--tile">{watermarkLine(img.photographerName)}</span>
                    </div>
                    <div class="tile-body">
                      {img.title && <h3 class="tile-title">{img.title}</h3>}
                      {img.caption && (
                        <p class="tile-caption">{img.caption.length > 120 ? img.caption.slice(0, 120) + '…' : img.caption}</p>
                      )}
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )}
        </>
      )}
    </div>

    <footer class="footer">
      <div class="footer-brand">Living Archive</div>
      <div class="footer-meta">
        <span>© 2026 Proximity Partners</span>
        <span class="footer-dot">·</span>
        <a href="mailto:chip@proximitypartnership.com">Contact</a>
      </div>
    </footer>
  </body>
</html>
