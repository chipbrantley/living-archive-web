---
import '../../styles/global.css';
import UserMenu from '../../components/UserMenu.astro';
import { fetchImageByNumber, fetchImageChips, prettyDate } from '../../lib/airtable';
import type { AirtableImage, PersonChip, PlaceChip, EventChip, OrgChip, LogEntry } from '../../lib/airtable';
import { photographerFullName as resolvePhotographer, watermarkLine as resolveWatermark, photographerSlug, captionSource, rightsHolder as resolveRightsHolder } from '../../lib/photographers';

const { id } = Astro.params;
const imageId = id ?? '';

let image: AirtableImage | null = null;
let people: PersonChip[] = [];
let places: PlaceChip[] = [];
let contextPlaces: PlaceChip[] = [];
let events: EventChip[] = [];
let orgs: OrgChip[] = [];
let log: LogEntry[] = [];
let error: string | null = null;

if (!imageId) {
  error = 'No image number provided.';
} else {
  try {
    // The Living Archive surface deliberately shows nothing of the print
    // inventory — the commercial side links here, never the reverse.
    image = await fetchImageByNumber(imageId);
    if (
      image &&
      (image.identificationIds.length || image.placeIds.length ||
        image.suggestionIds.length || image.eventIds.length || image.orgIds.length)
    ) {
      ({ people, places, contextPlaces, events, orgs, log } = await fetchImageChips(
        image.identificationIds,
        image.placeIds,
        image.suggestionIds,
        image.eventIds,
        image.orgIds
      ));
    }
  } catch (e) {
    error = e instanceof Error ? e.message : 'Unknown error.';
  }
}

const monogram = (name: string) =>
  name.split(/\s+/).filter(Boolean).slice(0, 2).map((w) => w[0].toUpperCase()).join('');

// Per-image source credit. Stanford's wording is their official citation, verbatim.
const SCAN_CREDITS: Record<string, string> = {
  'Stanford Special Collections':
    'Matt Herron photography archive (M2866). Dept. of Special Collections and University Archives, Stanford University (Matt and Jeannine Herron).',
  'Take Stock':
    'Take Stock, a picture agency specializing in images of social change.',
  'Estate of Matt Herron': 'The Estate of Matt Herron (Jeannine Herron).',
  'Proximity Partners': 'Proximity Partners print documentation.',
  'Jim Marshall Photography LLC': 'Courtesy of Jim Marshall Photography LLC.',
};
const scanCredit = image?.scanSource ? SCAN_CREDITS[image.scanSource] ?? null : null;

const pageTitle = image
  ? `Image ${image.imageNumber} — Living Archive`
  : `Image not found — Living Archive`;

const photographerFullName = resolvePhotographer(image?.photographerName ?? null);
const watermarkLine = resolveWatermark(image?.photographerName ?? null);
const captionSrc = captionSource(image?.photographerName ?? null);
const photogSlug = photographerSlug(image?.photographerName ?? null);
const rightsHolder = resolveRightsHolder(image?.photographerName ?? null);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href="/">
          <span class="brand-title">Living Archive</span>
        </a>
        <UserMenu />
      </div>
    </header>

    <nav class="breadcrumb">
      <a href="/">Browse</a>
      <span class="sep">›</span>
      <span>Image {imageId}</span>
    </nav>

    <div class="page">
      {error && (
        <div class="card">
          <div class="error-card">
            <strong>Something went wrong.</strong>
            <pre>{error}</pre>
          </div>
        </div>
      )}

      {!error && !image && (
        <div class="card">
          <h1 class="title">Image not found</h1>
          <p>
            We couldn't find image <strong>{imageId}</strong> in the archive.
            <a href="/">Back to start</a>
          </p>
        </div>
      )}

      {image && (
        <div class="card">
          {image.imageFile ? (
            <figure class="hero-image-wrap">
              <img
                src={image.imageFile.displayUrl}
                alt={image.caption ?? `${photographerFullName ?? 'Photograph'} #${image.imageNumber}`}
                width={image.imageFile.displayWidth}
                height={image.imageFile.displayHeight}
                loading="eager"
              />
              <span class="image-watermark">{watermarkLine}</span>
            </figure>
          ) : (
            <div class="hero-placeholder">
              <strong>Image #{image.imageNumber}</strong>
              Image file not yet uploaded — drop a JPG into the "Image file" attachment field on this Image record in Airtable.
            </div>
          )}

          {image.title ? (
            <h1 class="title">{image.title}</h1>
          ) : !image.caption ? (
            <h1 class="title">Image #{image.imageNumber}</h1>
          ) : null}

          {image.displayCaption ? (
            <>
              <div class="caption-kicker">Caption · Living Archive</div>
              <p class="caption">{image.displayCaption}</p>
              {image.caption && image.caption !== image.displayCaption && (
                <details class="caption-original">
                  <summary>Original caption{captionSrc ? ` · ${captionSrc}` : ''}</summary>
                  <p>{image.caption}</p>
                </details>
              )}
            </>
          ) : image.caption ? (
            <>
              <div class="caption-kicker">{captionSrc ? `Original caption · ${captionSrc}` : 'Caption · Living Archive'}</div>
              <p class="caption">{image.caption}</p>
            </>
          ) : null}

          {/* Canonical chip order: people · location · event · organizations · contextual */}
          {(people.length > 0 || places.length > 0 || contextPlaces.length > 0 || events.length > 0 || orgs.length > 0) && (
            <div class="chips">
              {people.map((p) => (
                <a
                  class={`chip chip-person${p.verified ? '' : ' chip-unverified'}`}
                  href={`/person/${p.slug}`}
                  title={p.verified ? `Identified in this photograph` : `Identification awaiting review`}
                >
                  <span class="chip-avatar">{monogram(p.name)}</span>
                  {p.name}
                </a>
              ))}
              {places.map((p) => (
                <a
                  class="chip chip-place"
                  href={`/place/${p.slug}`}
                  title={`Photographed in ${p.name}`}
                >{p.name}</a>
              ))}
              {events.map((ev) => (
                <a class="chip chip-event" href={`/event/${ev.slug}`}>{ev.name}</a>
              ))}
              {orgs.map((o) => (
                <span class="chip chip-org" title={o.acronym ? o.name : undefined}>
                  {o.acronym || o.name}
                </span>
              ))}
              {contextPlaces.map((p) => (
                <a
                  class="chip chip-place chip-place-context"
                  href={`/place/${p.slug}`}
                  title={p.via ? `Connected through ${p.via}` : `Connected to ${p.name}`}
                >{p.name}</a>
              ))}
            </div>
          )}

          <div class="subtitle">
            {image.photographerName && (
              photogSlug
                ? <a class="photog-pill photog-pill-link" href={`/photographer/${photogSlug}`}>{photographerFullName}</a>
                : <span class="photog-pill">{photographerFullName}</span>
            )}
            {image.dateTaken && <span class="date-taken">{prettyDate(image.dateTaken)}</span>}
            <span class="id-mono">Archive ID: {image.imageNumber}</span>
          </div>

          {scanCredit && (
            <div class="scan-credit">Source: {scanCredit}</div>
          )}

          {rightsHolder && (
            <div class="rights-repro">
              <span><strong>Rights &amp; reproductions:</strong> {rightsHolder}.</span>
              {photogSlug && (
                <a class="rights-repro-link" href={`/photographer/${photogSlug}#reproductions`}>
                  How to obtain copies →
                </a>
              )}
            </div>
          )}

        </div>
      )}

      {image && (
        <div class="contrib" id="contrib-card" data-image-number={image.imageNumber}>
          <div class="contrib-head">Help us learn about this image</div>
          <p class="contrib-sub">
            Do you recognize someone? Were you there, or do you know someone who was?
            Every detail helps return these photographs to the people and communities
            who lived this history.
          </p>
          <form id="contrib-form" autocomplete="off" novalidate>
            <div class="contrib-details" id="contrib-details">
              <div class="detail-row">
                <span class="detail-label">People</span>
                <div class="detail-fields">
                  <div class="ta-wrap">
                    <div class="contrib-people detail-chips" id="people-box">
                      <input
                        id="person-input"
                        type="text"
                        placeholder="Identify someone in this image — type a name…"
                        aria-label="Identify someone in this image"
                      />
                    </div>
                    <div class="contrib-suggest ta-drop" id="person-suggest" role="listbox" hidden></div>
                  </div>
                </div>
              </div>
              <div class="detail-row">
                <span class="detail-label">Location</span>
                <div class="detail-fields">
                  <div class="detail-grid">
                    <div class="ta-wrap"><input id="det-state" type="text" placeholder="State" /></div>
                    <div class="ta-wrap"><input id="det-county" type="text" placeholder="County" /></div>
                  </div>
                  <div class="detail-grid detail-grid-3">
                    <div class="ta-wrap"><input id="det-city" type="text" placeholder="City or town" /></div>
                    <div class="ta-wrap"><input id="det-neighborhood" type="text" placeholder="Neighborhood" /></div>
                    <div class="ta-wrap"><input id="det-venue" type="text" placeholder="Location name — church, school, office…" /></div>
                  </div>
                </div>
              </div>
              <div class="detail-row">
                <span class="detail-label">Date taken</span>
                <div class="detail-fields detail-date">
                  <input id="det-date" type="date" />
                  <label class="detail-checkbox">
                    <input id="det-approx" type="checkbox" /> Approximate
                  </label>
                </div>
              </div>
              <div class="detail-row">
                <span class="detail-label">Event or activity</span>
                <div class="detail-fields">
                  <div class="ta-wrap">
                    <div class="contrib-people detail-chips" id="events-box">
                      <input id="event-input" type="text" placeholder="Start typing — e.g. Selma to Montgomery March" />
                    </div>
                  </div>
                </div>
              </div>
              <div class="detail-row">
                <span class="detail-label">Organizations</span>
                <div class="detail-fields">
                  <div class="ta-wrap">
                    <div class="contrib-people detail-chips" id="orgs-box">
                      <input id="org-input" type="text" placeholder="Start typing — e.g. SNCC, COFO" />
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <textarea
              id="contrib-note"
              rows="3"
              placeholder="Anything else? Stories, context, connections — whatever the fields above can't hold."
            ></textarea>

            <input
              id="contrib-website"
              name="website"
              type="text"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
              class="contrib-hp"
            />
            <div class="contrib-actions">
              <span class="contrib-hint" id="contrib-hint"></span>
              <button type="submit" class="contrib-submit" id="contrib-submit">Submit</button>
            </div>
          </form>
          <div class="contrib-thanks" id="contrib-thanks" hidden>
            <strong>Thank you.</strong> Your contribution has been received and will be
            reviewed by the archive team. It's exactly this kind of knowledge that keeps
            this a living archive.
          </div>
        </div>
      )}

      {image && log.length > 0 && (
        <div class="card log-card">
          <div class="section-title">What the community has taught us</div>
          <ul class="log-list">
            {log.map((entry) => (
              <li class="log-row">
                <span class="log-text">
                  {entry.text}
                  {entry.by && <span class="log-by">— contributed by {entry.by}</span>}
                </span>
                {entry.date && <span class="log-date">{prettyDate(entry.date)}</span>}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <footer class="footer">
      <div class="footer-brand">Living Archive</div>
      <div class="footer-meta">
        <span>© 2026 Proximity Partners</span>
        <span class="footer-dot">·</span>
        <a href="mailto:chip@proximitypartnership.com">Contact</a>
      </div>
    </footer>

    <script is:inline>
      (function () {
        const card = document.getElementById('contrib-card');
        if (!card) return;
        const imageNumber = card.dataset.imageNumber;
        const form = document.getElementById('contrib-form');
        const noteEl = document.getElementById('contrib-note');
        const hint = document.getElementById('contrib-hint');
        const submitBtn = document.getElementById('contrib-submit');

        const initials = (name) =>
          name.split(/\s+/).filter(Boolean).slice(0, 2).map((w) => w[0].toUpperCase()).join('');

        // Defeat browser address-autofill: browsers ignore autocomplete="off"
        // on address-looking fields, but they skip readonly inputs. Start
        // every text field readonly and unlock on focus — invisible to the
        // user, invisible to the autofill heuristics. (The honeypot stays
        // writable on purpose: bots are welcome to fill it.)
        form.querySelectorAll('input[type="text"]').forEach((el) => {
          if (el.classList.contains('contrib-hp')) return;
          el.setAttribute('autocomplete', 'off');
          el.setAttribute('readonly', '');
          const unlock = () => el.removeAttribute('readonly');
          el.addEventListener('focus', unlock);
          el.addEventListener('pointerdown', unlock);
        });

        /**
         * Generic typeahead.
         *  input: text input element
         *  drop: dropdown element (created if not given)
         *  url(q): endpoint returning {results:[{id?,name,meta}]}
         *  onPick(item): item has {id?, name, isNew?}
         *  newLabel(q): label for the "+ suggest new" row, or null for closed sets
         *  avatars: render monogram circles (people)
         */
        function typeahead({ input, drop, url, onPick, newLabel, avatars }) {
          if (!drop) {
            drop = document.createElement('div');
            drop.className = 'contrib-suggest ta-drop';
            drop.hidden = true;
            (input.closest('.ta-wrap') || input.parentElement).appendChild(drop);
          }
          const hide = () => { drop.hidden = true; drop.innerHTML = ''; };
          let timer = null;
          input.addEventListener('input', () => {
            const q = input.value.trim();
            clearTimeout(timer);
            if (q.length < 1) { hide(); return; }
            timer = setTimeout(async () => {
              try {
                const res = await fetch(url(q));
                const data = await res.json();
                if (input.value.trim() !== q) return; // stale
                drop.innerHTML = '';
                const results = data.results || [];
                results.forEach((item) => {
                  const row = document.createElement('div');
                  row.className = 'suggest-item';
                  row.setAttribute('role', 'option');
                  if (avatars) {
                    const av = document.createElement('span');
                    av.className = 'suggest-avatar';
                    av.textContent = initials(item.name);
                    row.appendChild(av);
                  }
                  const nm = document.createElement('span');
                  nm.className = 'suggest-name';
                  nm.textContent = item.name;
                  row.appendChild(nm);
                  if (item.meta) {
                    const mt = document.createElement('span');
                    mt.className = 'suggest-meta';
                    mt.textContent = item.meta;
                    row.appendChild(mt);
                  }
                  row.addEventListener('click', () => { onPick(item); hide(); });
                  drop.appendChild(row);
                });
                if (newLabel && q.length >= 2) {
                  const addNew = document.createElement('div');
                  addNew.className = 'suggest-item suggest-new';
                  addNew.setAttribute('role', 'option');
                  addNew.textContent = newLabel(q);
                  addNew.addEventListener('click', () => { onPick({ name: q, isNew: true }); hide(); });
                  drop.appendChild(addNew);
                }
                drop.hidden = drop.children.length === 0;
              } catch (e) { hide(); }
            }, 180);
          });
          input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
              e.preventDefault();
              const first = drop.querySelector('.suggest-item');
              if (!drop.hidden && first) first.click();
            } else if (e.key === 'Escape') hide();
          });
          document.addEventListener('click', (e) => {
            if (!drop.contains(e.target) && e.target !== input) hide();
          });
          return { hide };
        }

        /** Chip collection rendered inside a .contrib-people box, before its input. */
        function chipSet(box, input) {
          const values = []; // {id?, name, isNew?}
          function render() {
            box.querySelectorAll('.pending-chip').forEach((c) => c.remove());
            values.forEach((v, i) => {
              const chip = document.createElement('span');
              chip.className = 'pending-chip' + (v.isNew ? ' pending-chip-new' : '');
              chip.textContent = v.name + (v.isNew ? ' (new)' : '');
              const x = document.createElement('button');
              x.type = 'button';
              x.className = 'pc-x';
              x.setAttribute('aria-label', 'remove ' + v.name);
              x.textContent = '×';
              x.addEventListener('click', () => { values.splice(i, 1); render(); });
              chip.appendChild(x);
              box.insertBefore(chip, input);
            });
          }
          input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace' && input.value === '' && values.length) {
              values.pop();
              render();
            }
          });
          return {
            values,
            add(v) {
              if (!values.some((c) => (v.id && c.id === v.id) || c.name === v.name)) {
                values.push(v);
                render();
              }
              input.value = '';
              input.focus();
            },
          };
        }

        // --- People: chips + typeahead with avatars and suggest-new ---
        const personInput = document.getElementById('person-input');
        const personChips = chipSet(document.getElementById('people-box'), personInput);
        typeahead({
          input: personInput,
          drop: document.getElementById('person-suggest'),
          url: (q) => '/api/people?q=' + encodeURIComponent(q),
          onPick: (item) => personChips.add(item),
          newLabel: (q) => '+ Suggest "' + q + '" as a name we don’t have yet',
          avatars: true,
        });

        // --- Location: Places-vocabulary typeaheads (fill-in style) ---
        const fill = (input) => (item) => { input.value = item.name; };
        const stateInput = document.getElementById('det-state');
        typeahead({
          input: stateInput,
          url: (q) => '/api/options?type=state&q=' + encodeURIComponent(q),
          onPick: fill(stateInput),
          newLabel: null, // closed set
        });
        const countyInput = document.getElementById('det-county');
        typeahead({
          input: countyInput,
          url: (q) =>
            '/api/options?type=county&q=' + encodeURIComponent(q) +
            '&state=' + encodeURIComponent(stateInput.value.trim()),
          onPick: fill(countyInput),
          newLabel: null, // closed set
        });
        for (const [id, kind, noun] of [
          ['det-city', 'city', 'place'],
          ['det-neighborhood', 'neighborhood', 'neighborhood'],
          ['det-venue', 'venue', 'location'],
        ]) {
          const el = document.getElementById(id);
          typeahead({
            input: el,
            url: (q) => '/api/options?type=' + kind + '&q=' + encodeURIComponent(q),
            onPick: fill(el),
            newLabel: (q) => '+ Use "' + q + '" — a ' + noun + ' we don’t have yet',
          });
        }

        // --- Events & Organizations: chips + vocabulary typeaheads ---
        const eventInput = document.getElementById('event-input');
        const eventChips = chipSet(document.getElementById('events-box'), eventInput);
        typeahead({
          input: eventInput,
          url: (q) => '/api/options?type=event&q=' + encodeURIComponent(q),
          onPick: (item) => eventChips.add(item),
          newLabel: (q) => '+ Suggest "' + q + '" as an event we don’t have yet',
        });
        const orgInput = document.getElementById('org-input');
        const orgChips = chipSet(document.getElementById('orgs-box'), orgInput);
        typeahead({
          input: orgInput,
          url: (q) => '/api/options?type=org&q=' + encodeURIComponent(q),
          onPick: (item) => orgChips.add(item),
          newLabel: (q) => '+ Suggest "' + q + '" as an organization we don’t have yet',
        });

        // --- Submit ---
        const detVal = (id) => document.getElementById(id).value.trim();
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const note = noteEl.value.trim();
          const detailsPayload = {
            state: detVal('det-state'),
            county: detVal('det-county'),
            city: detVal('det-city'),
            neighborhood: detVal('det-neighborhood'),
            venue: detVal('det-venue'),
            date: detVal('det-date'),
            approximate: document.getElementById('det-approx').checked,
            events: eventChips.values.map((v) => v.name),
            orgs: orgChips.values.map((v) => v.name),
          };
          const hasDetails = Object.values(detailsPayload).some(
            (v) => (Array.isArray(v) ? v.length : v !== '' && v !== false)
          );
          if (personChips.values.length === 0 && note === '' && !hasDetails) {
            hint.textContent = 'Name someone or tell us something first.';
            return;
          }
          hint.textContent = '';
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending…';
          try {
            const res = await fetch('/api/suggest', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                imageNumber,
                people: personChips.values.map((v) => ({ id: v.id, name: v.name })),
                note,
                details: detailsPayload,
                website: document.getElementById('contrib-website').value,
              }),
            });
            const data = await res.json();
            if (data.ok) {
              form.hidden = true;
              document.getElementById('contrib-thanks').hidden = false;
            } else {
              hint.textContent = data.error || 'Something went wrong — please try again.';
              submitBtn.disabled = false;
              submitBtn.textContent = 'Submit';
            }
          } catch (err) {
            hint.textContent = 'Network problem — please try again.';
            submitBtn.disabled = false;
            submitBtn.textContent = 'Submit';
          }
        });
      })();
    </script>
  </body>
</html>
