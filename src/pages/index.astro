---
import '../styles/global.css';
import { fetchImagesWithFiles, pingAirtable } from '../lib/airtable';

const error = await pingAirtable();
const allImages = error ? [] : await fetchImagesWithFiles();

// The browse front door is curated, not catalog-ordered: Featured images
// lead (shuffled each load so it feels alive), then the rest by image number.
function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
const featured = shuffle(allImages.filter((img) => img.featured));
const rest = allImages.filter((img) => !img.featured);
const images = [...featured, ...rest];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Living Archive</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href="/">
          <span class="brand-title">Living Archive</span>
        </a>
      </div>
    </header>

    <div class="page">
      {error && (
        <div class="card">
          <div class="error-card">
            <strong>Couldn't reach Airtable.</strong>
            <pre>{error}</pre>
          </div>
        </div>
      )}

      {!error && (
        <>
          <section class="intro">
            <h1 class="intro-title">Keeping our shared history alive.</h1>
            <p class="intro-text">
              A community-led initiative to contextualize Civil Rights-era photographs and then
              return them to the places where they were taken and to the people who lived the
              history they captured.
            </p>
          </section>

          <div class="search-wrap">
            <form class="search-bar" action="/search" method="get" role="search" autocomplete="off">
              <input
                id="site-search"
                type="search"
                name="q"
                placeholder="Search a name, a town, an event…"
                aria-label="Search the archive"
              />
              <button type="submit">Search</button>
            </form>
            <div class="search-drop" id="search-drop" role="listbox" hidden></div>
          </div>

          {images.length === 0 && (
            <div class="card">
              <p>No images with files yet. As image files get added to the Airtable base, they'll appear here.</p>
            </div>
          )}

          {images.length > 0 && (
            <section>
              <div class="browse-header">
                <h2 class="browse-title">Browse</h2>
                <span class="browse-count">{images.length} {images.length === 1 ? 'image' : 'images'}</span>
              </div>
              <div class="grid" id="browse-grid" data-page-size="48">
                {images.map((img, i) => (
                  <a class={`tile${i >= 48 ? ' tile-hidden' : ''}`} href={`/image/${img.imageNumber}`}>
                    <div class="tile-image-wrap">
                      {img.imageFile ? (
                        <>
                          <img
                            src={i < 48 ? img.imageFile.displayUrl : undefined}
                            data-src={img.imageFile.displayUrl}
                            alt={img.caption ?? `Image ${img.imageNumber}`}
                            loading="lazy"
                          />
                          <span class="image-watermark image-watermark--tile">
                            {(() => {
                              const photog = img.photographerName === 'MH' ? 'Matt Herron' : img.photographerName;
                              return photog ? `© ${photog} / Living Archive` : 'Living Archive';
                            })()}
                          </span>
                        </>
                      ) : (
                        <div class="tile-placeholder">No file</div>
                      )}
                    </div>
                    <div class="tile-body">
                      {img.title && (
                        <h3 class="tile-title">{img.title}</h3>
                      )}
                      {img.caption ? (
                        <p class="tile-caption">{img.caption}</p>
                      ) : !img.title ? (
                        <p class="tile-caption tile-caption-muted">Caption forthcoming</p>
                      ) : null}
                      <div class="tile-meta">
                        <span class="tile-photog">{img.photographerName === 'MH' ? 'Matt Herron' : (img.photographerName ?? 'Unknown')}</span>
                        <span class="tile-id">#{img.imageNumber}</span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
              {images.length > 48 && (
                <div class="show-more-wrap">
                  <button id="show-more" class="show-more">
                    Show more <span class="show-more-count">(showing 48 of {images.length})</span>
                  </button>
                </div>
              )}
            </section>
          )}
        </>
      )}
    </div>

    <footer class="footer">
      <div class="footer-brand">Living Archive</div>
    </footer>

    <script is:inline>
      (function () {
        // Live search dropdown: entity jumps + a "see all photographs" link.
        const input = document.getElementById('site-search');
        const drop = document.getElementById('search-drop');
        if (input && drop) {
          const TYPE = { person: 'Person', place: 'Place', event: 'Event' };
          const initials = (n) => n.split(/\s+/).filter(Boolean).slice(0, 2).map((w) => w[0].toUpperCase()).join('');
          const hide = () => { drop.hidden = true; drop.innerHTML = ''; };
          let timer = null;
          input.addEventListener('input', () => {
            const q = input.value.trim();
            clearTimeout(timer);
            if (q.length < 2) { hide(); return; }
            timer = setTimeout(async () => {
              try {
                const res = await fetch('/api/search?q=' + encodeURIComponent(q));
                const data = await res.json();
                if (input.value.trim() !== q) return;
                drop.innerHTML = '';
                (data.entities || []).forEach((e) => {
                  const a = document.createElement('a');
                  a.className = 'search-item';
                  a.href = e.url;
                  a.innerHTML =
                    (e.type === 'person' ? '<span class="chip-avatar"></span>' : '') +
                    '<span class="search-name"></span><span class="search-type"></span>';
                  if (e.type === 'person') a.querySelector('.chip-avatar').textContent = initials(e.name);
                  a.querySelector('.search-name').textContent = e.name;
                  a.querySelector('.search-type').textContent = TYPE[e.type] + (e.meta ? ' · ' + e.meta : '');
                  drop.appendChild(a);
                });
                if (data.imageCount > 0) {
                  const all = document.createElement('a');
                  all.className = 'search-item search-all';
                  all.href = '/search?q=' + encodeURIComponent(q);
                  all.textContent = `See all ${data.imageCount} photograph${data.imageCount === 1 ? '' : 's'} matching “${q}” →`;
                  drop.appendChild(all);
                }
                drop.hidden = drop.children.length === 0;
              } catch (e) { hide(); }
            }, 180);
          });
          input.addEventListener('keydown', (e) => { if (e.key === 'Escape') hide(); });
          document.addEventListener('click', (e) => {
            if (!drop.contains(e.target) && e.target !== input) hide();
          });
        }

        const grid = document.getElementById('browse-grid');
        const btn = document.getElementById('show-more');
        if (!grid || !btn) return;
        const pageSize = parseInt(grid.dataset.pageSize, 10) || 48;
        const tiles = Array.from(grid.querySelectorAll('.tile'));
        const countEl = btn.querySelector('.show-more-count');
        let shown = Math.min(pageSize, tiles.length);
        btn.addEventListener('click', () => {
          const next = Math.min(shown + pageSize, tiles.length);
          for (let i = shown; i < next; i++) {
            const tile = tiles[i];
            const img = tile.querySelector('img[data-src]');
            if (img && !img.src) img.src = img.dataset.src;
            tile.classList.remove('tile-hidden');
          }
          shown = next;
          if (shown >= tiles.length) {
            btn.remove();
          } else if (countEl) {
            countEl.textContent = `(showing ${shown} of ${tiles.length})`;
          }
        });
      })();
    </script>
  </body>
</html>
