---
import '../styles/global.css';
import { fetchImagesWithFiles, pingAirtable } from '../lib/airtable';

const error = await pingAirtable();
const images = error ? [] : await fetchImagesWithFiles();
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>The Living Archive</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href="/">
          <span class="brand-title">The Living Archive</span>
          <span class="brand-sub">A Proximity Partners project</span>
        </a>
      </div>
    </header>

    <div class="page">
      {error && (
        <div class="card">
          <div class="error-card">
            <strong>Couldn't reach Airtable.</strong>
            <pre>{error}</pre>
          </div>
        </div>
      )}

      {!error && (
        <>
          <section class="intro">
            <h1 class="intro-title">Keeping our shared history alive.</h1>
            <p class="intro-text">
              The Living Archive is a working space for civil-rights photography &mdash; identifying
              the people in the frame, gathering their stories, and returning the photographs to
              the families and communities they came from. It begins with the photographs of
              Matt Herron, with more photographers and collections to come.
            </p>
          </section>

          {images.length === 0 && (
            <div class="card">
              <p>No images with files yet. As image files get added to the Airtable base, they'll appear here.</p>
            </div>
          )}

          {images.length > 0 && (
            <section>
              <div class="browse-header">
                <h2 class="browse-title">Browse</h2>
                <span class="browse-count">{images.length} {images.length === 1 ? 'image' : 'images'}</span>
              </div>
              <div class="grid">
                {images.map((img) => (
                  <a class="tile" href={`/image/${img.imageNumber}`}>
                    <div class="tile-image-wrap">
                      {img.imageFile ? (
                        <img src={img.imageFile.url} alt={img.caption ?? `Image ${img.imageNumber}`} loading="lazy" />
                      ) : (
                        <div class="tile-placeholder">No file</div>
                      )}
                    </div>
                    <div class="tile-body">
                      {img.caption ? (
                        <p class="tile-caption">{img.caption}</p>
                      ) : (
                        <p class="tile-caption tile-caption-muted">Caption forthcoming</p>
                      )}
                      <div class="tile-meta">
                        <span class="tile-photog">{img.photographerName === 'MH' ? 'Matt Herron' : (img.photographerName ?? 'Unknown')}</span>
                        <span class="tile-id">#{img.imageNumber}</span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )}
        </>
      )}
    </div>

    <footer class="footer">
      <div class="footer-brand">The Living Archive</div>
    </footer>
  </body>
</html>
